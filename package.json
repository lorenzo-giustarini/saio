{
  "name": "revolution-dashboard",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Dashboard operativa interna Revolution Marketing — decisioni, task, orchestrator multi-terminal",
  "scripts": {
    "predev": "pwsh -NoProfile -File scripts/check-vite-cache.ps1",
    "dev": "vite",
    "dev:server": "tsx watch server/index.ts",
    "predev:all": "pwsh -NoProfile -File scripts/check-vite-cache.ps1",
    "dev:all": "concurrently -n vite,server -c cyan,magenta \"npm run dev\" \"npm run dev:server\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "orchestrator:dry": "python orchestrator/orchestrator.py --dry-run",
    "backup": "pwsh -File scripts/backup-data.ps1",
    "claim:reissue": "tsx scripts/claim-reissue.ts",
    "auth:reset": "tsx scripts/auth-reset.ts",
    "setup:deps": "node scripts/setup-deps-runner.js",
    "diag:orchestrator": "tsx scripts/diag-orchestrator.ts",
    "docs:cloudflare": "tsx scripts/generate-cloudflare-guide-pdf.ts",
    "postinstall": "node scripts/setup-deps-runner.js --check-only || true"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@octokit/rest": "^22.0.1",
    "@radix-ui/react-accordion": "^1.2.1",
