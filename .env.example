# Dashboard environment (uso locale, nessun secret in dashboard stessa)
# Copia in .env.local (git-ignored)

# Path (assoluti o relativi al repo root — default relativo)
DASHBOARD_DATA_DIR=./data
# Vault Obsidian personale (opzionale): percorso assoluto del tuo vault locale
VAULT_PATH=/path/to/your/obsidian-vault

# Porte
VITE_PORT=3030
SERVER_PORT=3031

# Rate limit orchestrator
MAX_CONCURRENT_TASKS=8

# Polling intervals (ms)
TASKS_POLL_INTERVAL=5000
BRIEFS_POLL_INTERVAL=10000
PROJECTS_POLL_INTERVAL=60000

# Heartbeat orchestrator (ms)
ORCHESTRATOR_HEARTBEAT_INTERVAL=3000
ORCHESTRATOR_STALE_THRESHOLD=10000

# ============================================================
# V15.0 WS3 — AUTH (single-owner self-hosted)
# ============================================================

# Master switch — false bypassa tutto auth (SOLO dev locale, mai in prod)
DASHBOARD_AUTH_REQUIRED=true

# Mittente magic link. Per Gmail SMTP usa stessa email del SMTP_USER.
# Per Resend in prod imposta 'auth@<tuo-dominio>' con DNS SPF/DKIM verificati.
DASHBOARD_AUTH_FROM=

# === EMAIL PROVIDER (scegline UNO) ===
#
# Opzione 1: SMTP (Gmail App Password / Outlook / qualsiasi SMTP)
# Per Gmail richiede 2FA + App Password (16 chars senza spazi):
#   https://myaccount.google.com/apppasswords
DASHBOARD_AUTH_SMTP_HOST=                    # es. smtp.gmail.com / smtp-mail.outlook.com
DASHBOARD_AUTH_SMTP_PORT=587                 # 587 (STARTTLS) o 465 (SSL)
DASHBOARD_AUTH_SMTP_USER=                    # tu@gmail.com
DASHBOARD_AUTH_SMTP_PASS=                    # Gmail App Password 16 chars

# Opzione 2: Resend (https://resend.com/api-keys, dominio verificato)
DASHBOARD_AUTH_RESEND_API_KEY=

# Opzione 3 (dev only): magic link in stdout invece che email reali
# DASHBOARD_AUTH_DEBUG_MAGIC_LINK=true (vedi sotto)

# JWT signing secret (64 hex chars random). Vuoto = auto-gen in data/auth/.jwt-secret
DASHBOARD_AUTH_JWT_SECRET=

# URL pubblico del tunnel Cloudflare (es. https://saio.tuoddominio.com).
# Usato per: 1) CORS allowlist, 2) costruzione URL absoluto dei magic link.
DASHBOARD_AUTH_TUNNEL_URL=

# Claim token TTL in minuti (default 5). Token rigenerato al restart se scaduto + owner non claimato.
DASHBOARD_AUTH_CLAIM_TTL_MIN=5

# Dev only: stampa magic link in stdout invece di inviare email (utile senza Resend setup).
DASHBOARD_AUTH_DEBUG_MAGIC_LINK=false

# Trust CF-Connecting-IP header (true se sei dietro Cloudflare Tunnel). Default true.
DASHBOARD_AUTH_TRUST_CLOUDFLARE=true
